import re
text = input("Enter a string: ")

match_pattern = input("Enter the pattern to match at the beginning: ")

search_pattern = input("Enter the pattern to search: ")

match_result = re.match(match_pattern, text)

if match_result:
    print("Match found at the beginning:", match_result.group())
else:
    print("No match found at the beginning.")
search_result = re.search(search_pattern, text)

if search_result:
    print("Search found:", search_result.group())
else:
    print("Pattern not found.")
